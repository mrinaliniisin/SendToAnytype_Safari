{
  "manifest_version": 3,
  "name": "Send to Anytype",
  "version": "1.0.2",
  "description": "Clip selected images and text from any webpage into your local Anytype (localhost:31009).",
  "action": {
    "default_title": "Send to Anytype: pick items to clip (⌥⇧A)",
    "default_icon": {
      "16": "icons/mark-16.png",
      "32": "icons/mark-32.png",
      "48": "icons/mark-48.png",
      "128": "icons/mark-128.png"
    }
  },
  "icons": {
    "16": "icons/mark-16.png",
    "32": "icons/mark-32.png",
    "48": "icons/mark-48.png",
    "64": "icons/mark-64.png",
    "96": "icons/mark-96.png",
    "128": "icons/mark-128.png",
    "256": "icons/mark-256.png",
    "512": "icons/mark-512.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+Shift+A" },
      "description": "Open Send to Anytype on the current page"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "sendtoanytype@anytype.local"
    }
  }
}
